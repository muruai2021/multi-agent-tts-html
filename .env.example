# MiniMax TTS 配置模板
# 使用方法: 复制本文件为 .env,然后填入真实值
#   cp .env.example .env   (macOS / Linux)
#   copy .env.example .env (Windows CMD)
#
# 申请 API Key: https://platform.minimaxi.com (国内版 minimaxi.com)

# ===== 必填 =====
# MiniMax API Key (Bearer Token)
MINIMAX_API_KEY=your_api_key_here

# ===== 可选:默认值覆盖 =====

# 默认输出目录(留空使用脚本内默认值 C:\Claude\wechat\)
# TTS_OUTPUT_DIR=C:/Claude/wechat/

# 默认音色(留空使用 国语男声)
# TTS_DEFAULT_VOICE=国语男声

# 默认音量 0.0-2.0(留空使用 1.5)
# TTS_DEFAULT_VOLUME=1.5

# ===== 音色预设对照(参考,脚本已内置) =====
# 国语男声: moss_audio_ce44fc67-7ce3-11f0-8de5-96e35d26fb85
# 国语女声: moss_audio_aaa1346a-7ce7-11f0-8e61-2e6e3c7ee85d
# 抒情男声: Chinese (Mandarin)_Lyrical_Voice
# 空乘女声: Chinese (Mandarin)_HK_Flight_Attendant
# 粤语女声: Cantonese_GentleLady
# 粤语播客: Cantonese_podacast_host_1
